#!/bin/sh
# Soket.io V3.0 - Configure Script
# Detects build environment, compiler availability, and architecture
# Outputs configuration for Makefile

set -e

echo "Soket.io V3.0 Configuration"
echo "================================="
echo ""

# Detect architecture
ARCH=$(uname -m)
case "$ARCH" in
    x86_64|amd64)
        ARCH_NAME="x86_64"
        CROSS_COMPILE=""
        ;;
    i386|i686)
        ARCH_NAME="i386"
        CROSS_COMPILE="i686-linux-musl-"
        ;;
    aarch64|arm64)
        ARCH_NAME="aarch64"
        CROSS_COMPILE="aarch64-linux-musl-"
        ;;
    armv7l)
        ARCH_NAME="armv7l"
        CROSS_COMPILE="armv7l-linux-musl-"
        ;;
    armv6l)
        ARCH_NAME="armv6l"
        CROSS_COMPILE="armv6l-linux-musl-"
        ;;
    *)
        echo "WARNING: Unknown architecture '$ARCH', defaulting to x86_64"
        ARCH_NAME="x86_64"
        CROSS_COMPILE=""
        ;;
esac

echo "Detected Architecture: $ARCH_NAME"

# Detect compiler
CC=""
if command -v musl-gcc >/dev/null 2>&1; then
    CC="musl-gcc"
    echo "Found musl-gcc (preferred for static builds)"
elif command -v gcc >/dev/null 2>&1; then
    CC="gcc"
    echo "Found gcc (musl-gcc recommended for static builds)"
elif command -v cc >/dev/null 2>&1; then
    CC="cc"
    echo "Found cc"
else
    echo "ERROR: No C compiler found"
    echo "Install gcc or musl-gcc:"
    echo "  Ubuntu/Debian: sudo apt install gcc musl-tools"
    echo "  Alpine: apk add gcc musl-dev"
    echo "  CentOS/RHEL: sudo yum install gcc"
    exit 1
fi

echo "Using Compiler: $CC"

# Test compiler
echo "Testing compiler..."
if $CC --version >/dev/null 2>&1; then
    CC_VERSION=$($CC --version 2>&1 | head -n 1)
    echo "Compiler OK: $CC_VERSION"
else
    echo "ERROR: Compiler test failed"
    exit 1
fi

# Check for required tools
echo "Checking build tools..."

TOOLS_REQUIRED="make sed find strip"
TOOLS_MISSING=""

for tool in $TOOLS_REQUIRED; do
    if ! command -v $tool >/dev/null 2>&1; then
        TOOLS_MISSING="$TOOLS_MISSING $tool"
    fi
done

if [ -n "$TOOLS_MISSING" ]; then
    echo "WARNING: Missing tools:$TOOLS_MISSING"
    echo "Some build features may not work"
else
    echo "All required tools found"
fi

# Detect OS
OS=$(uname -s)
echo "Operating System: $OS"

# Check for cross-compile toolchains
echo "Checking cross-compile toolchains..."

CROSS_TOOLS="x86_64-linux-musl-gcc i686-linux-musl-gcc aarch64-linux-musl-gcc armv7l-linux-musl-gcc armv6l-linux-musl-gcc"
CROSS_AVAILABLE=""

for cross in $CROSS_TOOLS; do
    if command -v $cross >/dev/null 2>&1; then
        CROSS_AVAILABLE="$CROSS_AVAILABLE $cross"
    fi
done

if [ -n "$CROSS_AVAILABLE" ]; then
    echo "Available cross-compilers:$CROSS_AVAILABLE"
else
    echo "No cross-compilers found (optional for multi-arch builds)"
    echo "Install musl-cross-make for cross-compilation support"
fi

# Create config.h
echo "Generating config.h..."

cat > include/config.h << EOF
/* Auto-generated by configure - DO NOT EDIT */
#ifndef PHANTOM_CONFIG_H
#define PHANTOM_CONFIG_H

#define PHANTOM_VERSION "3.0.0"
#define PHANTOM_ARCH "$ARCH_NAME"
#define PHANTOM_OS "$OS"
#define PHANTOM_CC "$CC"

/* Feature detection */
#define HAVE_EPOLL 1
#define HAVE_MEMFD_CREATE 1
#define HAVE_EXECVEAT 1

#endif /* PHANTOM_CONFIG_H */
EOF

echo "Created include/config.h"

# Create config.mk for Makefile
echo "Generating config.mk..."

cat > config.mk << EOF
# Auto-generated by configure - DO NOT EDIT
ARCH_NAME=$ARCH_NAME
CROSS_COMPILE=$CROSS_COMPILE
CC=$CC
OS=$OS
EOF

echo "Created config.mk"

# Summary
echo ""
echo "Configuration Summary"
echo "====================="
echo "Architecture:    $ARCH_NAME"
echo "Compiler:        $CC"
echo "OS:              $OS"
echo "Cross-compile:   $([ -n "$CROSS_COMPILE" ] && echo "$CROSS_COMPILE" || echo "native")"
echo ""
echo "Build commands:"
echo "  make              - Build client agent"
echo "  make x86_64       - Build for x86_64"
echo "  make i386         - Build for i386"
echo "  make aarch64      - Build for aarch64"
echo "  make armv7l       - Build for ARMv7"
echo "  make armv6l       - Build for ARMv6"
echo "  make all-arch     - Build all architectures"
echo "  make release      - Build release binary"
echo ""
echo "Ready to build. Run 'make' to compile."
